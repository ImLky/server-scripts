# ========== 콘솔 컬러 변수 ==========
# 사용법: source "$SCRIPT_DIR/colors.env"
# 다른 스크립트에서 $C_GREEN, $C_RED 등으로 사용

# 리셋
C_RST=$'\033[0m'

# 스타일
C_BOLD=$'\033[1m'
C_DIM=$'\033[2m'
C_ULINE=$'\033[4m'

# 전경색
C_RED=$'\033[31m'
C_GREEN=$'\033[32m'
C_YELLOW=$'\033[33m'
C_BLUE=$'\033[34m'
C_MAGENTA=$'\033[35m'
C_CYAN=$'\033[36m'
C_WHITE=$'\033[97m'

# 배경색
C_BG_RED=$'\033[41m'
C_BG_GREEN=$'\033[42m'
C_BG_YELLOW=$'\033[43m'
C_BG_BLUE=$'\033[44m'
C_BG_MAGENTA=$'\033[45m'
C_BG_CYAN=$'\033[46m'

# 조합 (자주 쓰는 패턴)
C_OK="${C_GREEN}${C_BOLD}"       # 성공
C_ERR="${C_RED}${C_BOLD}"        # 에러
C_WARN="${C_YELLOW}${C_BOLD}"    # 경고
C_INFO="${C_CYAN}"               # 정보
C_TITLE="${C_BG_BLUE}${C_WHITE}${C_BOLD}"  # 타이틀
