# ========== 콘솔 출력 헬퍼 함수 ==========
# 사용법: source "$SCRIPT_DIR/common/print.env"
# colors.env가 먼저 로드되어 있어야 함

# 타이틀 배너 출력
# 사용: print_title "제목 텍스트"
print_title() {
  local text="$1"
  local width=44
  printf "\n"
  printf "  %s%-${width}s%s\n" "$C_TITLE" "" "$C_RST"
  printf "  %s    %s%-$((width - 4))s%s\n" "$C_TITLE" "" "$text" "$C_RST"
  printf "  %s%-${width}s%s\n" "$C_TITLE" "" "$C_RST"
  printf "\n"
}

# 정보 라인 출력 (라벨: 값)
# 사용: print_info "라벨" "값"
print_info() {
  printf "  %s%s:%s  %s%s%s\n" "$C_DIM" "$1" "$C_RST" "$C_CYAN" "$2" "$C_RST"
}

# 구분선 출력
# 사용: print_line
print_line() {
  printf "  %s──────────────────────────────────────────────%s\n" "$C_DIM" "$C_RST"
}

# 명령어 항목 출력
# 사용: print_cmd "명령어" "설명"
print_cmd() {
  printf "\n"
  printf "  %s▸ ser %-10s%s  %s%s%s\n" "$C_OK" "$1" "$C_RST" "$C_WHITE" "$2" "$C_RST"
}

# 사용법 출력
# 사용: print_usage "ser dcs <서비스명> ..."
print_usage() {
  printf "    %s사용법%s %s│%s %s%s%s\n" "$C_YELLOW" "$C_RST" "$C_DIM" "$C_RST" "$C_CYAN" "$1" "$C_RST"
}

# 예시 출력
# 사용: print_example "ser dcs abc q-mes 10001 '테스트'"
print_example() {
  printf "    %s예시  %s %s│%s %s\$ %s%s%s\n" "$C_MAGENTA" "$C_RST" "$C_DIM" "$C_RST" "$C_DIM" "$C_RST" "$C_BLUE" "$1" "$C_RST"
}

# 성공 메시지
# 사용: print_ok "완료 메시지"
print_ok() {
  printf "%s✅ %s%s\n" "$C_OK" "$1" "$C_RST"
}

# 에러 메시지
# 사용: print_err "에러 메시지"
print_err() {
  printf "%s✗ %s%s\n" "$C_ERR" "$1" "$C_RST"
}

# 경고 메시지
# 사용: print_warn "경고 메시지"
print_warn() {
  printf "%s⚠ %s%s\n" "$C_WARN" "$1" "$C_RST"
}

# 정보 메시지
# 사용: print_msg "정보 메시지"
print_msg() {
  printf "%sℹ %s%s\n" "$C_INFO" "$1" "$C_RST"
}
