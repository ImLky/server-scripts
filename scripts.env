# ========== 서버 스크립트 환경 설정 ==========
# 스크립트 경로 (서버 환경에 맞게 수정)
# git pull 받고 source ~/.bashrc 하면 바로 적용됨 (환경변수 지정)
SCRIPT_DIR="/home/mes/server-scripts"

# ========== 공통 변수/함수 자동 로드 (common/*.env) ==========
for _env_file in "$SCRIPT_DIR/common"/*.env; do
  [ -f "$_env_file" ] && source "$_env_file"
done
unset _env_file

# ========== 자동 스캔 ==========
_SER_CMDS=()
declare -A _SER_DESC
declare -A _SER_USAGE
declare -A _SER_EXAMPLE
declare -A _SER_FILE

_scan_scripts() {
  local dir="$1"
  _SER_CMDS=()

  for script in "$dir"/*.sh; do
    [ -f "$script" ] || continue

    local cmd="" desc="" usage="" example=""
    while IFS= read -r line; do
      case "$line" in
        "# @cmd: "*)     cmd="${line#\# @cmd: }" ;;
        "# @desc: "*)    desc="${line#\# @desc: }" ;;
        "# @usage: "*)   usage="${line#\# @usage: }" ;;
        "# @example: "*) example="${line#\# @example: }" ;;
        "#"*)            continue ;;
        *)               break ;;
      esac
    done < "$script"

    [ -z "$cmd" ] && continue

    _SER_CMDS+=("$cmd")
    _SER_DESC["$cmd"]="$desc"
    _SER_USAGE["$cmd"]="$usage"
    _SER_EXAMPLE["$cmd"]="$example"
    _SER_FILE["$cmd"]="$(basename "$script")"
  done
}

_scan_scripts "$SCRIPT_DIR"

# ========== ser: 단일 진입점 ==========
ser() {
  local subcmd="${1:-help}"
  shift 2>/dev/null || true

  if [[ "$subcmd" == "help" ]]; then
    _ser_help
    return 0
  fi

  if [[ -n "${_SER_FILE[$subcmd]+x}" ]]; then
    bash "$SCRIPT_DIR/${_SER_FILE[$subcmd]}" "$@"
    return $?
  fi

  print_err "알 수 없는 명령어: $subcmd"
  printf "  %sser help 로 사용 가능한 명령어를 확인하세요.%s\n\n" "$C_DIM" "$C_RST"
  return 1
}

# ========== 도움말 ==========
_ser_help() {
  print_title "🖥  서버 관리 스크립트 (ser)"
  print_info "사용법" "ser <명령어> [인자...]"
  print_info "경  로" "$SCRIPT_DIR"
  print_info "등  록" "${#_SER_CMDS[@]}개 명령어"
  printf "\n"
  print_line

  for cmd in "${_SER_CMDS[@]}"; do
    print_cmd "$cmd" "${_SER_DESC[$cmd]}"
    [ -n "${_SER_USAGE[$cmd]}" ] && print_usage "${_SER_USAGE[$cmd]}"
    [ -n "${_SER_EXAMPLE[$cmd]}" ] && print_example "${_SER_EXAMPLE[$cmd]}"
  done

  print_cmd "help" "이 도움말 표시"
  print_cmd "reload" "스크립트 최신화 후 도움말"
  printf "\n"
  print_line
  printf "\n"
}

# ========== ser 자동완성 ==========
_ser_completions() {
  local cur="${COMP_WORDS[COMP_CWORD]}"
  COMPREPLY=($(compgen -W "${_SER_CMDS[*]} help reload" -- "$cur"))
}
complete -F _ser_completions ser
