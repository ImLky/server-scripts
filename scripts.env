# ========== 서버 스크립트 환경 설정 ==========
# 스크립트 경로 (서버 환경에 맞게 수정)
SCRIPT_DIR="/home/mes/server-scripts"

# ========== 자동 스캔 및 명령어 등록 ==========
_CMD_LIST=()
declare -A _CMD_DESC
declare -A _CMD_USAGE
declare -A _CMD_EXAMPLE
declare -A _CMD_FILE

_scan_scripts() {
  local dir="$1"
  for script in "$dir"/*.sh; do
    [ -f "$script" ] || continue

    local cmd="" desc="" usage="" example=""
    while IFS= read -r line; do
      case "$line" in
        "# @cmd: "*)     cmd="${line#\# @cmd: }" ;;
        "# @desc: "*)    desc="${line#\# @desc: }" ;;
        "# @usage: "*)   usage="${line#\# @usage: }" ;;
        "# @example: "*) example="${line#\# @example: }" ;;
        "#"*)            continue ;;
        *)               break ;;
      esac
    done < "$script"

    [ -z "$cmd" ] && continue

    _CMD_LIST+=("$cmd")
    _CMD_DESC["$cmd"]="$desc"
    _CMD_USAGE["$cmd"]="$usage"
    _CMD_EXAMPLE["$cmd"]="$example"
    _CMD_FILE["$cmd"]="$(basename "$script")"

    eval "${cmd}() { bash \"\$SCRIPT_DIR/${_CMD_FILE[$cmd]}\" \"\$@\"; }"
  done
}

_scan_scripts "$SCRIPT_DIR"

# ========== 도움말 함수 ==========
shelp() {
  echo ""
  echo "=========================================="
  echo "  서버 관리 스크립트 명령어 모음"
  echo "=========================================="
  echo ""
  echo "  스크립트 경로: $SCRIPT_DIR"
  echo ""

  for cmd in "${_CMD_LIST[@]}"; do
    printf "  %-14s | %s\n" "$cmd" "${_CMD_DESC[$cmd]}"
    [ -n "${_CMD_USAGE[$cmd]}" ] && \
      printf "  %-14s | 사용법: %s\n" "" "${_CMD_USAGE[$cmd]}"
    [ -n "${_CMD_EXAMPLE[$cmd]}" ] && \
      printf "  %-14s | 예시:   %s\n" "" "${_CMD_EXAMPLE[$cmd]}"
    echo "  ---------------+------------------------------------------"
  done

  printf "  %-14s | %s\n" "shelp" "이 도움말 표시"
  echo "  ---------------+------------------------------------------"
  echo ""
  echo "  적용 방법: source $SCRIPT_DIR/scripts.env"
  echo ""
  echo "=========================================="
}
