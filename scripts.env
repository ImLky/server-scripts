# ========== 서버 스크립트 환경 설정 ==========
# 스크립트 경로 (서버 환경에 맞게 수정)
# git pull 받고 source ~/.bashrc 하면 바로 적용됨 (환경변수 지정)
SCRIPT_DIR="/home/mes/server-scripts"

# ========== 자동 스캔 ==========
_SER_CMDS=()
declare -A _SER_DESC
declare -A _SER_USAGE
declare -A _SER_EXAMPLE
declare -A _SER_FILE

_scan_scripts() {
  local dir="$1"
  _SER_CMDS=()

  for script in "$dir"/*.sh; do
    [ -f "$script" ] || continue

    local cmd="" desc="" usage="" example=""
    while IFS= read -r line; do
      case "$line" in
        "# @cmd: "*)     cmd="${line#\# @cmd: }" ;;
        "# @desc: "*)    desc="${line#\# @desc: }" ;;
        "# @usage: "*)   usage="${line#\# @usage: }" ;;
        "# @example: "*) example="${line#\# @example: }" ;;
        "#"*)            continue ;;
        *)               break ;;
      esac
    done < "$script"

    [ -z "$cmd" ] && continue

    _SER_CMDS+=("$cmd")
    _SER_DESC["$cmd"]="$desc"
    _SER_USAGE["$cmd"]="$usage"
    _SER_EXAMPLE["$cmd"]="$example"
    _SER_FILE["$cmd"]="$(basename "$script")"
  done
}

_scan_scripts "$SCRIPT_DIR"

# ========== ser: 단일 진입점 ==========
ser() {
  local subcmd="${1:-help}"
  shift 2>/dev/null || true

  # help 서브커맨드
  if [[ "$subcmd" == "help" ]]; then
    _ser_help
    return 0
  fi

  # 등록된 서브커맨드 실행
  if [[ -n "${_SER_FILE[$subcmd]+x}" ]]; then
    bash "$SCRIPT_DIR/${_SER_FILE[$subcmd]}" "$@"
    return $?
  fi

  # 미등록 서브커맨드
  printf "\n  \033[31m✗ 알 수 없는 명령어: %s\033[0m\n" "$subcmd"
  printf "  \033[2mser help 로 사용 가능한 명령어를 확인하세요.\033[0m\n\n"
  return 1
}

# ========== 도움말 ==========
_ser_help() {
  local RST=$'\033[0m'
  local BOLD=$'\033[1m'
  local DIM=$'\033[2m'
  local CYAN=$'\033[36m'
  local GREEN=$'\033[32m'
  local YELLOW=$'\033[33m'
  local BLUE=$'\033[34m'
  local MAGENTA=$'\033[35m'
  local WHITE=$'\033[97m'
  local RED=$'\033[31m'
  local BG=$'\033[44m'

  printf "\n"
  printf "  %s%s%s                                            %s\n" "$BG" "$WHITE" "$BOLD" "$RST"
  printf "  %s%s%s    🖥  서버 관리 스크립트 (ser)             %s\n" "$BG" "$WHITE" "$BOLD" "$RST"
  printf "  %s%s%s                                            %s\n" "$BG" "$WHITE" "$BOLD" "$RST"
  printf "\n"
  printf "  %s사용법:%s  %sser <명령어> [인자...]%s\n" "$DIM" "$RST" "$CYAN" "$RST"
  printf "  %s경  로:%s  %s%s%s\n" "$DIM" "$RST" "$CYAN" "$SCRIPT_DIR" "$RST"
  printf "  %s등  록:%s  %s%s개 명령어%s\n" "$DIM" "$RST" "$CYAN" "${#_SER_CMDS[@]}" "$RST"
  printf "\n"
  printf "  %s──────────────────────────────────────────────%s\n" "$DIM" "$RST"

  for cmd in "${_SER_CMDS[@]}"; do
    printf "\n"
    printf "  %s%s▸ ser %-10s%s  %s%s%s\n" "$GREEN" "$BOLD" "$cmd" "$RST" "$WHITE" "${_SER_DESC[$cmd]}" "$RST"
    [ -n "${_SER_USAGE[$cmd]}" ] && \
      printf "    %s사용법%s %s│%s %s%s%s\n" "$YELLOW" "$RST" "$DIM" "$RST" "$CYAN" "${_SER_USAGE[$cmd]}" "$RST"
    [ -n "${_SER_EXAMPLE[$cmd]}" ] && \
      printf "    %s예시  %s %s│%s %s\$ %s%s%s%s\n" "$MAGENTA" "$RST" "$DIM" "$RST" "$DIM" "$RST" "$BLUE" "${_SER_EXAMPLE[$cmd]}" "$RST"
  done

  printf "\n"
  printf "  %s%s▸ ser %-10s%s  %s이 도움말 표시%s\n" "$GREEN" "$BOLD" "help" "$RST" "$WHITE" "$RST"
  printf "  %s%s▸ ser %-10s%s  %s스크립트 최신화 후 도움말%s\n" "$GREEN" "$BOLD" "reload" "$RST" "$WHITE" "$RST"
  printf "\n"
  printf "  %s──────────────────────────────────────────────%s\n" "$DIM" "$RST"
  printf "\n"
}

# ========== ser 자동완성 ==========
_ser_completions() {
  local cur="${COMP_WORDS[COMP_CWORD]}"
  COMPREPLY=($(compgen -W "${_SER_CMDS[*]} help reload" -- "$cur"))
}
complete -F _ser_completions ser
