# ========== 서버 스크립트 함수 ==========
# 스크립트 경로 (서버 환경에 맞게 수정)
SCRIPT_DIR="/home/mes/server-scripts"

dcs() { bash "$SCRIPT_DIR/dockerComposeSeting.sh" "$@"; }
del() { bash "$SCRIPT_DIR/del.sh" "$@"; }
restart() { bash "$SCRIPT_DIR/restart.sh" "$@"; }
allrestart() { bash "$SCRIPT_DIR/allRestart.sh"; }
allpull() { bash "$SCRIPT_DIR/allGitPull.sh"; }
setupsh() { bash "$SCRIPT_DIR/setup_sh.sh" "$@"; }
