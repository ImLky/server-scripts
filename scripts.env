# ========== 서버 스크립트 환경 설정 ==========
# 스크립트 경로 (서버 환경에 맞게 수정)
# git pull 받고 source ~/.bashrc 하면 바로 적용됨 (환경변수 지정)
SCRIPT_DIR="/home/mes/server-scripts"

# ========== 자동 스캔 및 명령어 등록 ==========
_CMD_LIST=()
declare -A _CMD_DESC
declare -A _CMD_USAGE
declare -A _CMD_EXAMPLE
declare -A _CMD_FILE

_scan_scripts() {
  local dir="$1"
  for script in "$dir"/*.sh; do
    [ -f "$script" ] || continue

    local cmd="" desc="" usage="" example=""
    while IFS= read -r line; do
      case "$line" in
        "# @cmd: "*)     cmd="${line#\# @cmd: }" ;;
        "# @desc: "*)    desc="${line#\# @desc: }" ;;
        "# @usage: "*)   usage="${line#\# @usage: }" ;;
        "# @example: "*) example="${line#\# @example: }" ;;
        "#"*)            continue ;;
        *)               break ;;
      esac
    done < "$script"

    [ -z "$cmd" ] && continue

    _CMD_LIST+=("$cmd")
    _CMD_DESC["$cmd"]="$desc"
    _CMD_USAGE["$cmd"]="$usage"
    _CMD_EXAMPLE["$cmd"]="$example"
    _CMD_FILE["$cmd"]="$(basename "$script")"

    eval "${cmd}() { bash \"\$SCRIPT_DIR/${_CMD_FILE[$cmd]}\" \"\$@\"; }"
  done
}

_scan_scripts "$SCRIPT_DIR"

# ========== 도움말 함수 ==========
shelp() {
  # 컬러 정의 ($'...' ANSI-C 쿼팅 — RedHat/CentOS bash 호환)
  local RST=$'\033[0m'
  local BOLD=$'\033[1m'
  local DIM=$'\033[2m'
  local CYAN=$'\033[36m'
  local GREEN=$'\033[32m'
  local YELLOW=$'\033[33m'
  local BLUE=$'\033[34m'
  local MAGENTA=$'\033[35m'
  local WHITE=$'\033[97m'
  local BG=$'\033[44m'

  printf "\n"
  printf "  %s%s%s                                            %s\n" "$BG" "$WHITE" "$BOLD" "$RST"
  printf "  %s%s%s    🖥  서버 관리 스크립트 명령어 모음       %s\n" "$BG" "$WHITE" "$BOLD" "$RST"
  printf "  %s%s%s                                            %s\n" "$BG" "$WHITE" "$BOLD" "$RST"
  printf "\n"
  printf "  %s📂 스크립트 경로:%s %s%s%s\n" "$DIM" "$RST" "$CYAN" "$SCRIPT_DIR" "$RST"
  printf "  %s📋 등록된 명령어:%s %s%s개%s\n" "$DIM" "$RST" "$CYAN" "${#_CMD_LIST[@]}" "$RST"
  printf "\n"
  printf "  %s──────────────────────────────────────────────%s\n" "$DIM" "$RST"

  for cmd in "${_CMD_LIST[@]}"; do
    printf "\n"
    printf "  %s%s▸ %-12s%s  %s─%s  %s%s%s\n" "$GREEN" "$BOLD" "$cmd" "$RST" "$DIM" "$RST" "$WHITE" "${_CMD_DESC[$cmd]}" "$RST"
    [ -n "${_CMD_USAGE[$cmd]}" ] && \
      printf "    %s사용법%s %s│%s %s%s%s\n" "$YELLOW" "$RST" "$DIM" "$RST" "$CYAN" "${_CMD_USAGE[$cmd]}" "$RST"
    [ -n "${_CMD_EXAMPLE[$cmd]}" ] && \
      printf "    %s예시  %s %s│%s %s\$ %s%s%s%s\n" "$MAGENTA" "$RST" "$DIM" "$RST" "$DIM" "$RST" "$BLUE" "${_CMD_EXAMPLE[$cmd]}" "$RST"
  done

  printf "\n"
  printf "  %s%s▸ %-12s%s  %s─%s  %s이 도움말 표시%s\n" "$GREEN" "$BOLD" "shelp" "$RST" "$DIM" "$RST" "$WHITE" "$RST"
  printf "\n"
  printf "  %s──────────────────────────────────────────────%s\n" "$DIM" "$RST"
  printf "  %s적용 방법:%s %ssource %s/scripts.env%s\n" "$DIM" "$RST" "$CYAN" "$SCRIPT_DIR" "$RST"
  printf "  %s──────────────────────────────────────────────%s\n" "$DIM" "$RST"
  printf "\n"
}
